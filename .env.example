# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# Comma-separated Telegram user IDs allowed to use the bot.
# To find your ID: message @userinfobot on Telegram.
# Leave empty to allow anyone (not recommended).
ALLOWED_USER_IDS=123456789

# Forum mode: set to your Telegram group chat ID (negative number).
# Create a group, enable Topics, add the bot as admin.
# Each /new creates a topic + pane. Leave empty for DM mode.
TELEGRAM_GROUP_ID=

# Machine name for topic grouping (defaults to hostname).
# Topics are named "[MACHINE] session-name" so you can tell
# which machine owns each session at a glance.
MACHINE_NAME=
